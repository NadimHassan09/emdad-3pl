PORT=3000
DATABASE_URL="postgresql://user:password@localhost:5432/emdad_3pl?schema=public"
# Limit Prisma connection pool (recommended for Render/Aiven: 3-5)
# DATABASE_CONNECTION_LIMIT=5

# JWT (required for auth)
JWT_SECRET=your-secret-key-min-32-chars
JWT_ACCESS_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_IN=604800

# SMTP (for invitation emails)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# SMTP_FROM=noreply@example.com

# Client portal base URL (for invitation login links)
# CLIENT_PORTAL_URL=https://your-client-portal.onrender.com

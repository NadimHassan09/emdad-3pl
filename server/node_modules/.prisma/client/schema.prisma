// =============================================================================
// Prisma schema - 3PL WMS Backend
// =============================================================================
//
// The canonical database structure is defined in the project context:
//   /context/schema.sql
//
// Use Prisma introspection against an existing PostgreSQL database, or
// run migrations, depending on environment. Do not duplicate model
// definitions here until aligned with schema.sql.
//

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// IAM (aligned with /context/schema.sql)
// -----------------------------------------------------------------------------

enum ClientStatus {
  ACTIVE
  SUSPENDED
  CLOSED

  @@map("client_status")
}

enum ActorType {
  INTERNAL_USER
  CLIENT_ACCOUNT
  SYSTEM

  @@map("actor_type")
}

model Client {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code         String       @unique @db.VarChar(50)
  name         String       @db.VarChar(255)
  contactEmail String?      @map("contact_email") @db.VarChar(255)
  contactPhone String?      @map("contact_phone") @db.VarChar(50)
  addressLine1 String?      @map("address_line1") @db.VarChar(255)
  city         String?      @db.VarChar(100)
  stateRegion  String?      @map("state_region") @db.VarChar(100)
  postalCode   String?      @map("postal_code") @db.VarChar(20)
  countryCode  String?      @map("country_code") @db.Char(2)
  balanceCents BigInt       @default(0) @map("balance_cents") @db.BigInt
  currency     String       @default("USD") @db.Char(3)
  status       ClientStatus @default(ACTIVE)
  isActive     Boolean      @default(true) @map("is_active") @db.Boolean
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime     @default(now()) @map("updated_at") @db.Timestamptz(6)

  clientAccounts      ClientAccount[]
  products            Product[]
  inventoryLedgers    InventoryLedger[]
  currentStocks       CurrentStock[]
  inboundOrders       InboundOrder[]
  outboundOrders      OutboundOrder[]
  returnOrders        ReturnOrder[]
  taskWorkOrders      TaskWorkOrder[]
  stockReservations   StockReservation[]
  outboundAllocations OutboundAllocation[]
  adjustments         Adjustment[]
  clientBillingPlans  ClientBillingPlan[]
  invoices            Invoice[]
  billingTransactions BillingTransaction[]
  notifications       ClientNotification[]

  @@map("client")
}

model ClientNotification {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId      String   @map("client_id") @db.Uuid
  title         String   @db.VarChar(255)
  message       String   @db.Text
  importance    String   @default("MEDIUM") @db.VarChar(20)
  referenceType String?  @map("reference_type") @db.VarChar(100)
  referenceId   String?  @map("reference_id") @db.VarChar(255)
  isRead        Boolean  @default(false) @map("is_read") @db.Boolean
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([clientId, isRead])
  @@map("client_notification")
}

model ClientRole {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleName        String   @unique @map("role_name") @db.VarChar(100)
  permissionsJson Json     @default("{}") @map("permissions_json") @db.JsonB
  isActive        Boolean  @default(true) @map("is_active") @db.Boolean
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  clientAccounts ClientAccount[]

  @@map("client_roles")
}

model ClientAccount {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId     String   @map("client_id") @db.Uuid
  clientRoleId String   @map("client_role_id") @db.Uuid
  email        String   @unique @db.VarChar(255)
  passwordHash String?  @map("password_hash") @db.VarChar(255)
  firstName    String   @map("first_name") @db.VarChar(100)
  lastName     String   @map("last_name") @db.VarChar(100)
  isActive     Boolean  @default(true) @map("is_active") @db.Boolean
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  client     Client     @relation(fields: [clientId], references: [id], onDelete: Restrict)
  clientRole ClientRole @relation(fields: [clientRoleId], references: [id], onDelete: Restrict)
  actor      Actor?

  @@index([clientId])
  @@map("client_account")
}

model UserRole {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleName        String   @unique @map("role_name") @db.VarChar(100)
  permissionsJson Json     @default("{}") @map("permissions_json") @db.JsonB
  isActive        Boolean  @default(true) @map("is_active") @db.Boolean
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  users User[]

  @@map("user_roles")
}

model User {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email          String   @unique @db.VarChar(255)
  passwordHash   String?  @map("password_hash") @db.VarChar(255)
  firstName      String   @map("first_name") @db.VarChar(100)
  lastName       String   @map("last_name") @db.VarChar(100)
  internalRoleId String?  @map("internal_role_id") @db.Uuid
  warehouseId    String?  @map("warehouse_id") @db.Uuid
  isActive       Boolean  @default(true) @map("is_active") @db.Boolean
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  internalRole  UserRole?       @relation(fields: [internalRoleId], references: [id], onDelete: SetNull)
  warehouse     Warehouse?      @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  actor         Actor?
  assignedTasks TaskWorkOrder[]

  @@index([internalRoleId])
  @@index([warehouseId])
  @@map("users")
}

model Actor {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorType       ActorType @map("actor_type")
  userId          String?   @unique @map("user_id") @db.Uuid
  clientAccountId String?   @unique @map("client_account_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  user               User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientAccount      ClientAccount?  @relation(fields: [clientAccountId], references: [id], onDelete: Cascade)
  inboundOrders      InboundOrder[]
  outboundOrders     OutboundOrder[]
  adjustments        Adjustment[]
  requestedApprovals Approval[]      @relation("RequestedApprovals")
  approvedApprovals  Approval[]      @relation("ApprovedApprovals")
  auditLogs          AuditLog[]

  @@index([actorType])
  @@map("actor")
}

// -----------------------------------------------------------------------------
// Master Data (aligned with /context/schema.sql)
// -----------------------------------------------------------------------------

enum UomDimension {
  COUNT
  LENGTH
  WEIGHT
  VOLUME
  TEMPERATURE

  @@map("uom_dimension")
}

enum LocationType {
  ZONE
  AISLE
  RACK
  BIN
  STAGING

  @@map("location_type")
}

enum BatchStatus {
  AVAILABLE
  HOLD
  QUARANTINE
  EXPIRED
  CONSUMED

  @@map("batch_status")
}

enum MovementType {
  RECEIPT
  PUTAWAY
  PICK
  SHIPMENT
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
  RETURN
  CYCLE_COUNT

  @@map("movement_type")
}

enum OrderStatus {
  DRAFT
  PENDING
  CONFIRMED
  IN_PROGRESS
  RECEIVING
  SHIPPED
  COMPLETED
  CANCELLED

  @@map("order_status")
}

enum TaskType {
  RECEIVING
  PUTAWAY
  PICKING
  PACKING
  SHIPPING
  CYCLE_COUNT
  REPLENISHMENT
  ADJUSTMENT

  @@map("task_type")
}

enum TaskStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED

  @@map("task_status")
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT

  @@map("task_priority")
}

enum AdjustmentStatus {
  PENDING
  APPROVED
  REJECTED
  APPLIED

  @@map("adjustment_status")
}

enum ReturnDisposition {
  RESTOCK
  DAMAGED
  QUARANTINE
  DISPOSAL

  @@map("return_disposition")
}

enum ReservationStatus {
  DRAFT
  CONFIRMED
  RELEASED
  CANCELLED

  @@map("reservation_status")
}

enum AllocationStatus {
  RESERVED
  PARTIALLY_PICKED
  PICKED
  PARTIALLY_SHIPPED
  SHIPPED
  CANCELLED

  @@map("allocation_status")
}

model Uom {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code           String       @unique @db.VarChar(20)
  name           String       @db.VarChar(100)
  dimension      UomDimension
  baseConversion Decimal      @default(1) @map("base_conversion") @db.Decimal(18, 6)
  isActive       Boolean      @default(true) @map("is_active") @db.Boolean
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @default(now()) @map("updated_at") @db.Timestamptz(6)

  warehouses         Warehouse[]
  locations          Location[]
  products           Product[]
  inboundOrderItems  InboundOrderItem[]
  outboundOrderItems OutboundOrderItem[]
  vasPricings        VasPricing[]

  @@map("uom")
}

model Warehouse {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code          String   @unique @db.VarChar(50)
  name          String   @db.VarChar(255)
  capacityValue Decimal? @map("capacity_value") @db.Decimal(18, 4)
  capacityUomId String?  @map("capacity_uom_id") @db.Uuid
  isActive      Boolean  @default(true) @map("is_active") @db.Boolean
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  users               User[]
  capacityUom         Uom?                 @relation(fields: [capacityUomId], references: [id], onDelete: SetNull)
  locations           Location[]
  inventoryLedgers    InventoryLedger[]
  currentStocks       CurrentStock[]
  inboundOrders       InboundOrder[]
  outboundOrders      OutboundOrder[]
  returnOrders        ReturnOrder[]
  taskWorkOrders      TaskWorkOrder[]
  stockReservations   StockReservation[]
  outboundAllocations OutboundAllocation[]
  adjustments         Adjustment[]

  @@map("warehouse")
}

model Location {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  warehouseId      String       @map("warehouse_id") @db.Uuid
  parentLocationId String?      @map("parent_location_id") @db.Uuid
  code             String       @db.VarChar(50)
  locationType     LocationType @map("location_type")
  capacityValue    Decimal?     @map("capacity_value") @db.Decimal(18, 4)
  capacityUomId    String?      @map("capacity_uom_id") @db.Uuid
  isActive         Boolean      @default(true) @map("is_active") @db.Boolean
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime     @default(now()) @map("updated_at") @db.Timestamptz(6)

  warehouse                Warehouse                @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  parentLocation           Location?                @relation("LocationHierarchy", fields: [parentLocationId], references: [id], onDelete: Cascade)
  childLocations           Location[]               @relation("LocationHierarchy")
  capacityUom              Uom?                     @relation(fields: [capacityUomId], references: [id], onDelete: SetNull)
  inventoryLedgers         InventoryLedger[]
  currentStocks            CurrentStock[]
  inboundOrderItemBatches  InboundOrderItemBatch[]
  outboundOrderItemBatches OutboundOrderItemBatch[]
  outboundAllocations      OutboundAllocation[]
  adjustments              Adjustment[]

  @@unique([warehouseId, code])
  @@index([warehouseId, parentLocationId])
  @@map("location")
}

model Product {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId           String   @map("client_id") @db.Uuid
  sku                String   @db.VarChar(100)
  name               String   @db.VarChar(255)
  description        String?  @db.Text
  category           String?  @db.VarChar(100)
  brand              String?  @db.VarChar(100)
  price              Decimal? @db.Decimal(18, 4)
  declaredValue      Decimal? @map("declared_value") @db.Decimal(18, 4)
  defaultUomId       String   @map("default_uom_id") @db.Uuid
  weight             Decimal? @default(0) @db.Decimal(18, 4)
  lengthCm           Decimal? @default(0) @map("length_cm") @db.Decimal(18, 4)
  widthCm            Decimal? @default(0) @map("width_cm") @db.Decimal(18, 4)
  heightCm           Decimal? @default(0) @map("height_cm") @db.Decimal(18, 4)
  unitsPerCarton     Int?     @default(1) @map("units_per_carton") @db.Integer
  barcode            String?  @db.VarChar(100)
  isSerialized       Boolean  @default(false) @map("is_serialized") @db.Boolean
  isBatchTracked     Boolean  @default(false) @map("is_batch_tracked") @db.Boolean
  requiresExpiryDate Boolean  @default(false) @map("requires_expiry_date") @db.Boolean
  minThreshold       Decimal? @default(0) @map("min_threshold") @db.Decimal(18, 4)
  reorderPoint       Decimal? @map("reorder_point") @db.Decimal(18, 4)
  isActive           Boolean  @default(true) @map("is_active") @db.Boolean
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  client              Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  defaultUom          Uom                  @relation(fields: [defaultUomId], references: [id], onDelete: Restrict)
  batches             Batch[]
  inventoryLedgers    InventoryLedger[]
  currentStocks       CurrentStock[]
  inboundOrderItems   InboundOrderItem[]
  outboundOrderItems  OutboundOrderItem[]
  returnOrders        ReturnOrder[]
  outboundAllocations OutboundAllocation[]
  adjustments         Adjustment[]

  @@unique([clientId, sku])
  @@map("product")
}

model Batch {
  id                String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId         String      @map("product_id") @db.Uuid
  batchCode         String      @map("batch_code") @db.VarChar(100)
  expiryDate        DateTime?   @map("expiry_date") @db.Date
  manufacturingDate DateTime?   @map("manufacturing_date") @db.Date
  receivedDate      DateTime?   @map("received_date") @db.Date
  lotNumber         String?     @map("lot_number") @db.VarChar(100)
  supplierBatchCode String?     @map("supplier_batch_code") @db.VarChar(100)
  batchStatus       BatchStatus @default(AVAILABLE) @map("batch_status")
  createdAt         DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime    @default(now()) @map("updated_at") @db.Timestamptz(6)

  product                  Product                  @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryLedgers         InventoryLedger[]
  currentStocks            CurrentStock[]
  inboundOrderItemBatches  InboundOrderItemBatch[]
  outboundOrderItemBatches OutboundOrderItemBatch[]
  returnOrders             ReturnOrder[]
  outboundAllocations      OutboundAllocation[]
  adjustments              Adjustment[]

  @@unique([productId, batchCode])
  @@index([batchStatus])
  @@map("batch")
}

// -----------------------------------------------------------------------------
// Inventory Tracking (aligned with /context/schema.sql)
// -----------------------------------------------------------------------------

model InventoryLedger {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId      String       @map("client_id") @db.Uuid
  warehouseId   String       @map("warehouse_id") @db.Uuid
  productId     String       @map("product_id") @db.Uuid
  batchId       String?      @map("batch_id") @db.Uuid
  locationId    String?      @map("location_id") @db.Uuid
  movementType  MovementType @map("movement_type")
  qtyChange     Decimal      @map("qty_change") @db.Decimal(18, 4)
  qtyBefore     Decimal      @map("qty_before") @db.Decimal(18, 4)
  qtyAfter      Decimal      @map("qty_after") @db.Decimal(18, 4)
  referenceType String?      @map("reference_type") @db.VarChar(50)
  referenceId   String?      @map("reference_id") @db.Uuid
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  client    Client    @relation(fields: [clientId], references: [id], onDelete: Restrict)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Restrict)
  batch     Batch?    @relation(fields: [batchId], references: [id], onDelete: SetNull)
  location  Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@index([clientId, warehouseId, productId, createdAt])
  @@map("inventory_ledger")
}

model CurrentStock {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId    String   @map("client_id") @db.Uuid
  warehouseId String   @map("warehouse_id") @db.Uuid
  productId   String   @map("product_id") @db.Uuid
  batchId     String?  @map("batch_id") @db.Uuid
  locationId  String?  @map("location_id") @db.Uuid
  quantity    Decimal  @default(0) @db.Decimal(18, 4)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  batch     Batch?    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  location  Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([clientId, warehouseId, productId, batchId, locationId], name: "idx_current_stock_unique")
  @@index([clientId, warehouseId, productId])
  @@map("current_stock")
}

// -----------------------------------------------------------------------------
// Inbound Orders (aligned with /context/schema.sql)
// -----------------------------------------------------------------------------

model InboundOrder {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId         String      @map("client_id") @db.Uuid
  warehouseId      String?     @map("warehouse_id") @db.Uuid
  orderNumber      String?     @map("order_number") @db.VarChar(50)
  status           OrderStatus @default(DRAFT)
  currentStage     String?     @map("current_stage") @db.VarChar(100)
  expectedDate     DateTime?   @map("expected_date") @db.Date
  createdByActorId String      @map("created_by_actor_id") @db.Uuid
  createdAt        DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  client         Client             @relation(fields: [clientId], references: [id], onDelete: Restrict)
  warehouse      Warehouse?         @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  createdByActor Actor              @relation(fields: [createdByActorId], references: [id], onDelete: Restrict)
  items          InboundOrderItem[]

  @@index([clientId, warehouseId])
  @@map("inbound_order")
}

model InboundOrderItem {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  inboundOrderId String   @map("inbound_order_id") @db.Uuid
  productId      String   @map("product_id") @db.Uuid
  qtyOrdered     Decimal  @map("qty_ordered") @db.Decimal(18, 4)
  qtyReceived    Decimal  @default(0) @map("qty_received") @db.Decimal(18, 4)
  uomId          String   @map("uom_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  inboundOrder InboundOrder            @relation(fields: [inboundOrderId], references: [id], onDelete: Cascade)
  product      Product                 @relation(fields: [productId], references: [id], onDelete: Restrict)
  uom          Uom                     @relation(fields: [uomId], references: [id], onDelete: Restrict)
  batches      InboundOrderItemBatch[]

  @@index([inboundOrderId])
  @@map("inbound_order_item")
}

model InboundOrderItemBatch {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  inboundOrderItemId String   @map("inbound_order_item_id") @db.Uuid
  batchId            String?  @map("batch_id") @db.Uuid
  locationId         String?  @map("location_id") @db.Uuid
  qtyReceived        Decimal  @default(0) @map("qty_received") @db.Decimal(18, 4)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  inboundOrderItem InboundOrderItem @relation(fields: [inboundOrderItemId], references: [id], onDelete: Cascade)
  batch            Batch?           @relation(fields: [batchId], references: [id], onDelete: SetNull)
  location         Location?        @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@index([inboundOrderItemId])
  @@map("inbound_order_item_batch")
}

// -----------------------------------------------------------------------------
// Outbound Orders (aligned with /context/schema.sql)
// -----------------------------------------------------------------------------

model OutboundOrder {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId         String      @map("client_id") @db.Uuid
  warehouseId      String?     @map("warehouse_id") @db.Uuid
  orderNumber      String?     @map("order_number") @db.VarChar(50)
  status           OrderStatus @default(DRAFT)
  currentStage     String?     @map("current_stage") @db.VarChar(100)
  expectedShipDate DateTime?   @map("expected_ship_date") @db.Date
  createdByActorId String      @map("created_by_actor_id") @db.Uuid
  createdAt        DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  client            Client              @relation(fields: [clientId], references: [id], onDelete: Restrict)
  warehouse         Warehouse?          @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  createdByActor    Actor               @relation(fields: [createdByActorId], references: [id], onDelete: Restrict)
  items             OutboundOrderItem[]
  stockReservations StockReservation[]
  returnOrders      ReturnOrder[]

  @@index([clientId, warehouseId])
  @@map("outbound_order")
}

model OutboundOrderItem {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  outboundOrderId String   @map("outbound_order_id") @db.Uuid
  productId       String   @map("product_id") @db.Uuid
  qtyOrdered      Decimal  @map("qty_ordered") @db.Decimal(18, 4)
  qtyShipped      Decimal  @default(0) @map("qty_shipped") @db.Decimal(18, 4)
  uomId           String   @map("uom_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  outboundOrder OutboundOrder            @relation(fields: [outboundOrderId], references: [id], onDelete: Cascade)
  product       Product                  @relation(fields: [productId], references: [id], onDelete: Restrict)
  uom           Uom                      @relation(fields: [uomId], references: [id], onDelete: Restrict)
  batches       OutboundOrderItemBatch[]
  allocations   OutboundAllocation[]

  @@index([outboundOrderId])
  @@map("outbound_order_item")
}

model OutboundOrderItemBatch {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  outboundOrderItemId String   @map("outbound_order_item_id") @db.Uuid
  batchId             String?  @map("batch_id") @db.Uuid
  locationId          String?  @map("location_id") @db.Uuid
  qtyShipped          Decimal  @default(0) @map("qty_shipped") @db.Decimal(18, 4)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  outboundOrderItem OutboundOrderItem @relation(fields: [outboundOrderItemId], references: [id], onDelete: Cascade)
  batch             Batch?            @relation(fields: [batchId], references: [id], onDelete: SetNull)
  location          Location?         @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@index([outboundOrderItemId])
  @@map("outbound_order_item_batch")
}

// -----------------------------------------------------------------------------
// Stock Reservations (aligned with /context/schema.sql)
// -----------------------------------------------------------------------------

model StockReservation {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId        String            @map("client_id") @db.Uuid
  warehouseId     String            @map("warehouse_id") @db.Uuid
  outboundOrderId String            @map("outbound_order_id") @db.Uuid
  status          ReservationStatus @default(DRAFT)
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  client        Client               @relation(fields: [clientId], references: [id], onDelete: Restrict)
  warehouse     Warehouse            @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  outboundOrder OutboundOrder        @relation(fields: [outboundOrderId], references: [id], onDelete: Cascade)
  allocations   OutboundAllocation[]

  @@index([outboundOrderId])
  @@index([clientId, warehouseId])
  @@map("stock_reservation")
}

model OutboundAllocation {
  id                  String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  stockReservationId  String           @map("stock_reservation_id") @db.Uuid
  outboundOrderItemId String           @map("outbound_order_item_id") @db.Uuid
  clientId            String           @map("client_id") @db.Uuid
  warehouseId         String           @map("warehouse_id") @db.Uuid
  productId           String           @map("product_id") @db.Uuid
  batchId             String?          @map("batch_id") @db.Uuid
  locationId          String?          @map("location_id") @db.Uuid
  reservedQty         Decimal          @default(0) @map("reserved_qty") @db.Decimal(18, 4)
  pickedQty           Decimal          @default(0) @map("picked_qty") @db.Decimal(18, 4)
  shippedQty          Decimal          @default(0) @map("shipped_qty") @db.Decimal(18, 4)
  status              AllocationStatus @default(RESERVED)
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  stockReservation  StockReservation  @relation(fields: [stockReservationId], references: [id], onDelete: Cascade)
  outboundOrderItem OutboundOrderItem @relation(fields: [outboundOrderItemId], references: [id], onDelete: Cascade)
  client            Client            @relation(fields: [clientId], references: [id], onDelete: Restrict)
  warehouse         Warehouse         @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  product           Product           @relation(fields: [productId], references: [id], onDelete: Restrict)
  batch             Batch?            @relation(fields: [batchId], references: [id], onDelete: SetNull)
  location          Location?         @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@index([stockReservationId])
  @@index([outboundOrderItemId])
  @@index([clientId, warehouseId, productId])
  @@map("outbound_allocation")
}

// -----------------------------------------------------------------------------
// Task Work Orders (aligned with /context/schema.sql)
// -----------------------------------------------------------------------------

model TaskWorkOrder {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId        String       @map("client_id") @db.Uuid
  warehouseId     String       @map("warehouse_id") @db.Uuid
  taskType        TaskType     @map("task_type")
  referenceType   String?      @map("reference_type") @db.VarChar(50)
  referenceId     String?      @map("reference_id") @db.Uuid
  referenceItemId String?      @map("reference_item_id") @db.Uuid
  assignedUserId  String?      @map("assigned_user_id") @db.Uuid
  priority        TaskPriority @default(NORMAL)
  status          TaskStatus   @default(PENDING)
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  client       Client    @relation(fields: [clientId], references: [id], onDelete: Restrict)
  warehouse    Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  assignedUser User?     @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)

  @@index([clientId, warehouseId])
  @@index([referenceType, referenceId])
  @@index([referenceType, referenceItemId])
  @@map("task_work_order")
}

// -----------------------------------------------------------------------------
// Adjustments (aligned with /context/schema.sql)
// -----------------------------------------------------------------------------

model Adjustment {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId         String           @map("client_id") @db.Uuid
  warehouseId      String           @map("warehouse_id") @db.Uuid
  productId        String?          @map("product_id") @db.Uuid
  batchId          String?          @map("batch_id") @db.Uuid
  locationId       String?          @map("location_id") @db.Uuid
  qtyChange        Decimal          @map("qty_change") @db.Decimal(18, 4)
  reason           String?          @db.Text
  status           AdjustmentStatus @default(PENDING)
  createdByActorId String           @map("created_by_actor_id") @db.Uuid
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  client         Client    @relation(fields: [clientId], references: [id], onDelete: Restrict)
  warehouse      Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  product        Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  batch          Batch?    @relation(fields: [batchId], references: [id], onDelete: SetNull)
  location       Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  createdByActor Actor     @relation(fields: [createdByActorId], references: [id], onDelete: Restrict)

  @@index([clientId, warehouseId])
  @@map("adjustment")
}

// -----------------------------------------------------------------------------
// Return Orders (aligned with /context/schema.sql)
// -----------------------------------------------------------------------------

model ReturnOrder {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId        String            @map("client_id") @db.Uuid
  warehouseId     String            @map("warehouse_id") @db.Uuid
  outboundOrderId String            @map("outbound_order_id") @db.Uuid
  returnNumber    String            @map("return_number") @db.VarChar(50)
  productId       String            @map("product_id") @db.Uuid
  batchId         String?           @map("batch_id") @db.Uuid
  qty             Decimal           @db.Decimal(18, 4)
  disposition     ReturnDisposition @default(RESTOCK)
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  client        Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  warehouse     Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  outboundOrder OutboundOrder @relation(fields: [outboundOrderId], references: [id], onDelete: Restrict)
  product       Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  batch         Batch?        @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@index([clientId, warehouseId])
  @@index([outboundOrderId])
  @@map("return_order")
}

// -----------------------------------------------------------------------------
// Approvals (aligned with /context/schema.sql)
// -----------------------------------------------------------------------------

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("approval_status")
}

enum ApprovalReferenceType {
  ADJUSTMENT
  RETURN
  INVOICE
  ORDER

  @@map("approval_reference_type")
}

model Approval {
  id                 String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  referenceType      ApprovalReferenceType @map("reference_type")
  referenceId        String                @map("reference_id") @db.Uuid
  approvalStep       String                @default("INITIAL") @map("approval_step") @db.VarChar(50)
  sequenceNo         Int                   @default(1) @map("sequence_no")
  requestedByActorId String                @map("requested_by_actor_id") @db.Uuid
  approvedByActorId  String?               @map("approved_by_actor_id") @db.Uuid
  status             ApprovalStatus        @default(PENDING)
  requestNotes       String?               @map("request_notes")
  decisionNotes      String?               @map("decision_notes")
  decisionAt         DateTime?             @map("decision_at") @db.Timestamptz(6)
  createdAt          DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime              @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  requestedByActor Actor  @relation("RequestedApprovals", fields: [requestedByActorId], references: [id], onDelete: Restrict)
  approvedByActor  Actor? @relation("ApprovedApprovals", fields: [approvedByActorId], references: [id], onDelete: SetNull)

  @@index([referenceType, referenceId], name: "idx_approval_reference")
  @@index([requestedByActorId], name: "idx_approval_requested")
  @@map("approval")
}

// -----------------------------------------------------------------------------
// Billing & Finance (aligned with /context/schema.sql)
// -----------------------------------------------------------------------------

enum BillingCycleEnum {
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY

  @@map("billing_cycle_enum")
}

enum PricingMethod {
  FIXED
  PER_UNIT
  PER_VOLUME
  PER_WEIGHT
  CUSTOM

  @@map("pricing_method")
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  OVERDUE
  CANCELLED

  @@map("invoice_status")
}

enum ChargeCategory {
  STORAGE
  MOVEMENT
  VAS
  PLAN_FEE
  MANUAL_CREDIT
  MANUAL_CHARGE

  @@map("charge_category")
}

model BillingPlan {
  id                       String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  planName                 String           @map("plan_name") @db.VarChar(100)
  storageIncluded          Decimal?         @map("storage_included") @db.Decimal(18, 4)
  billingCycle             BillingCycleEnum @map("billing_cycle")
  baseFeeCents             BigInt?          @default(0) @map("base_fee_cents") @db.BigInt
  inboundItemFeeCents      BigInt?          @default(0) @map("inbound_item_fee_cents") @db.BigInt
  inboundWeightCentsPerKg  BigInt?          @default(0) @map("inbound_weight_cents_per_kg") @db.BigInt
  outboundItemFeeCents     BigInt?          @default(0) @map("outbound_item_fee_cents") @db.BigInt
  outboundWeightCentsPerKg BigInt?          @default(0) @map("outbound_weight_cents_per_kg") @db.BigInt
  isActive                 Boolean          @default(true) @map("is_active") @db.Boolean
  createdAt                DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime         @default(now()) @map("updated_at") @db.Timestamptz(6)

  clientBillingPlans ClientBillingPlan[]
  vasPricings        VasPricing[]

  @@map("billing_plan")
}

model Vas {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String   @unique @db.VarChar(50)
  name        String   @db.VarChar(255)
  description String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active") @db.Boolean
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  vasPricings VasPricing[]

  @@map("vas")
}

model VasPricing {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vasId          String        @map("vas_id") @db.Uuid
  billingPlanId  String        @map("billing_plan_id") @db.Uuid
  pricingMethod  PricingMethod @default(FIXED) @map("pricing_method")
  rateCents      BigInt        @map("rate_cents") @db.BigInt
  baseUomId      String?       @map("base_uom_id") @db.Uuid
  minChargeCents BigInt?       @map("min_charge_cents") @db.BigInt
  billingUnit    String?       @map("billing_unit") @db.VarChar(50)
  ruleJson       Json          @default("{}") @map("rule_json") @db.JsonB
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)

  vas         Vas         @relation(fields: [vasId], references: [id], onDelete: Cascade)
  billingPlan BillingPlan @relation(fields: [billingPlanId], references: [id], onDelete: Cascade)
  baseUom     Uom?        @relation(fields: [baseUomId], references: [id], onDelete: SetNull)

  @@unique([vasId, billingPlanId])
  @@map("vas_pricing")
}

model ClientBillingPlan {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId      String    @map("client_id") @db.Uuid
  billingPlanId String    @map("billing_plan_id") @db.Uuid
  startsAt      DateTime  @default(now()) @map("starts_at") @db.Timestamptz(6)
  endsAt        DateTime? @map("ends_at") @db.Timestamptz(6)
  isCurrent     Boolean   @default(true) @map("is_current") @db.Boolean
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  client      Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  billingPlan BillingPlan @relation(fields: [billingPlanId], references: [id], onDelete: Restrict)

  @@index([clientId])
  @@map("client_billing_plan")
}

model Invoice {
  id                  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId            String        @map("client_id") @db.Uuid
  invoiceNumber       String        @unique @map("invoice_number") @db.VarChar(50)
  periodStart         DateTime      @map("period_start") @db.Date
  periodEnd           DateTime      @map("period_end") @db.Date
  subtotalCents       BigInt        @default(0) @map("subtotal_cents") @db.BigInt
  taxAmountCents      BigInt        @default(0) @map("tax_amount_cents") @db.BigInt
  discountAmountCents BigInt        @default(0) @map("discount_amount_cents") @db.BigInt
  totalAmountCents    BigInt        @default(0) @map("total_amount_cents") @db.BigInt
  currency            String        @default("USD") @db.Char(3)
  status              InvoiceStatus @default(DRAFT)
  dueDate             DateTime?     @map("due_date") @db.Date
  issuedAt            DateTime?     @map("issued_at") @db.Timestamptz(6)
  paidAt              DateTime?     @map("paid_at") @db.Timestamptz(6)
  notes               String?       @db.Text
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)

  client              Client               @relation(fields: [clientId], references: [id], onDelete: Restrict)
  lines               InvoiceLine[]
  billingTransactions BillingTransaction[]

  @@index([clientId])
  @@map("invoice")
}

model InvoiceLine {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId        String         @map("invoice_id") @db.Uuid
  chargeCategory   ChargeCategory @map("charge_category")
  description      String?        @db.Text
  quantity         Decimal        @default(0) @db.Decimal(18, 4)
  unitPriceCents   BigInt         @map("unit_price_cents") @db.BigInt
  totalAmountCents BigInt         @map("total_amount_cents") @db.BigInt
  currency         String         @default("USD") @db.Char(3)
  referenceType    String?        @map("reference_type") @db.VarChar(100)
  referenceId      String?        @map("reference_id") @db.Uuid
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime       @default(now()) @map("updated_at") @db.Timestamptz(6)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([referenceType, referenceId])
  @@map("invoice_line")
}

model BillingTransaction {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId       String         @map("client_id") @db.Uuid
  invoiceId      String?        @map("invoice_id") @db.Uuid
  chargeCategory ChargeCategory @map("charge_category")
  description    String?        @db.Text
  amountCents    BigInt         @map("amount_cents") @db.BigInt
  currency       String         @default("USD") @db.Char(3)
  referenceType  String?        @map("reference_type") @db.VarChar(100)
  referenceId    String?        @map("reference_id") @db.Uuid
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  client  Client   @relation(fields: [clientId], references: [id], onDelete: Restrict)
  invoice Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([invoiceId])
  @@index([referenceType, referenceId])
  @@map("billing_transaction")
}

// -----------------------------------------------------------------------------
// System Audit (append-only, immutable; aligned with /context/schema.sql)
// -----------------------------------------------------------------------------

model AuditLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId      String?  @map("actor_id") @db.Uuid
  action       String   @db.VarChar(100)
  resourceType String   @map("resource_type") @db.VarChar(100)
  resourceId   String?  @map("resource_id") @db.Uuid
  ipAddress    String?  @map("ip_address") @db.Inet
  detailsJson  Json     @default("{}") @map("details_json") @db.JsonB
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  actor Actor? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId], name: "idx_audit_log_actor")
  @@index([resourceType, resourceId], name: "idx_audit_log_resource")
  @@index([createdAt], name: "idx_audit_log_created")
  @@map("audit_log")
}
